# ── 数据库 ────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=           # 必填
DB_NAME=ship_digital_db

# ── 高德地图 ──────────────────────────────────────
AMAP_KEY=              # 必填，从高德开放平台获取

# ── 服务自身 ──────────────────────────────────────
SERVICE_HOST=localhost  # 对外暴露的 IP 或域名（云服务器填公网IP）
SERVICE_PORT=8000

# ── CORS（逗号分隔，填前端实际域名） ──────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── 存储路径 ──────────────────────────────────────
OUTPUT_DIR=data/output
UPLOAD_DIR=data/upload

# ── AI / Ollama ───────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=deepseek-r1:8b

# ── Consul ────────────────────────────────────────
USE_CONSUL_CONFIG=false          # 连队友数据库时改为 true
CONSUL_HOST=localhost             # 队友 Consul IP，如 192.168.31.75
CONSUL_PORT=8500
CONSUL_KV_KEY=config/ship-backend-app,dev/data  # Consul 里存配置的完整 key
