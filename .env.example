# ── 数据库 ────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=           # 必填
DB_NAME=ship_digital_db

# ── 高德地图 ──────────────────────────────────────
AMAP_KEY=              # 必填，从高德开放平台获取

# ── 服务自身 ──────────────────────────────────────
SERVICE_HOST=localhost  # 对外暴露的 IP 或域名（云服务器填公网IP）
SERVICE_PORT=8000

# ── CORS（逗号分隔，填前端实际域名） ──────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── 存储路径 ──────────────────────────────────────
OUTPUT_DIR=data/output
UPLOAD_DIR=data/upload

# ── AI / Ollama ───────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=deepseek-r1:8b

# ── Java 后端 ─────────────────────────────────────
JAVA_API_BASE_URL=http://localhost:8080
JAVA_API_TOKEN=

# ── Consul（云端一般不需要，保持 false） ──────────
USE_CONSUL_CONFIG=false
CONSUL_HOST=localhost
CONSUL_PORT=8500
